# Optional: Massive.com (Polygon.io) API key for highly accurate pre-market and intraday data
# Get your key at https://massive.com/dashboard/keys
# If provided, Massive.com will be the primary data source with Finnhub/Yahoo as fallbacks
VITE_MASSIVE_API_KEY=

# Optional: Finnhub API key for improved live stock data
# Get your free key at https://finnhub.io/
# Without this key, the app will fall back to Yahoo Finance and demo data
VITE_FINNHUB_API_KEY=
